# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# NOTE: public/charting_library/ (TradingView, proprietary, ~26MB) is intentionally committed so the
# chart works on Vercel/production. Keep this repo PRIVATE - the library is not redistributable.

# typescript
*.tsbuildinfo
next-env.d.ts

